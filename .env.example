## RTSP
# Examples:
# RTSP_URL=rtsp://admin:password@192.168.0.10:554/cam/realmonitor?channel=1&subtype=0
# RTSP_URL=rtsp://user:pass@<camera-ip>:554/live
RTSP_URL=

## YOLO / Inference
# For CPU only, keep empty or set to "cpu"
# For GPU (if available): "cuda"
DEVICE=cpu
YOLO_MODEL=yolov8n.pt
CONF_THRES=0.35
IOU_THRES=0.45

## Activity aggregation
AGGREGATION_SECONDS=60
# If motion_score >= MOTION_ACTIVE_THRESHOLD -> Working(True) else Idle(False)
MOTION_ACTIVE_THRESHOLD=18.0
# How often to attempt RTSP reconnect when stream fails
RECONNECT_BACKOFF_SECONDS=2

## Zones config
ZONES_CONFIG_PATH=config/zones.yaml

## Supabase
SUPABASE_URL=
# Use service role key for server-side inserts (keep secret)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_TABLE=kitchen_activity
